#!/usr/bin/env bash
image=mdmitry1/python311-dev:latest
if [ $# -gt 0 ]; then 
    image=$1
    shift
fi
mkdir -p "$HOME/shared"
ip=$(hostname -I | tr ' ' '\n' | grep -Ev '^172|^127|:|^$' | head -1)
display=$(echo "$DISPLAY" | cut -d: -f2)
pkill socat &> /dev/null
socat TCP4-LISTEN:600${display},bind=$ip,reuseaddr,fork UNIX-CONNECT:/tmp/.X11-unix/X${display} &
if [[ -z "${TZ}" ]]; then
    TZ=$(readlink /etc/localtime | sed 's@/usr/share/zoneinfo/@@')
fi
arch=$(docker image inspect $image --format '{{.Architecture}}')
if [ "arm64" == $arch ]; then
    platform="--platform linux/aarch64"
else
    platform=""
fi
docker run -e DISPLAY="${ip}:${display}" \
           -e TZ="$TZ" \
           -e NO_AT_BRIDGE=1 \
           --network host \
           $platform \
           -v "$HOME/shared:/shared" \
           -it $image "$@"
